{
  "name": "workout-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "dotenv -e .env.development -- tsx scripts/start-postgres.ts",
    "dev": "next dev",
    "prepwa:dev": "dotenv -e .env.development -- tsx scripts/start-postgres.ts",
    "pwa:dev": "dotenv -e .env.development -e .env.pwa.development -- next dev --experimental-https",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:up": "dotenv -e .env.development -- tsx scripts/start-postgres.ts",
    "db:down": "docker compose down",
    "db:seed": "dotenv -e .env.development -- prisma db seed",
    "prisma:generate": "dotenv -e .env.development -- prisma generate",
    "prisma:migrate": "dotenv -e .env.development -- prisma migrate dev",
    "prisma:studio": "dotenv -e .env.development -- prisma studio"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/material-nextjs": "^9.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "next": "16.2.9",
    "pg": "^8.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
